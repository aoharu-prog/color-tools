/* ===== BASE ===== */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--tx);font-family:var(--fb);font-weight:300;line-height:1.9;overflow-x:hidden;transition:background .75s,color .75s}

/* ===== SWITCHER ===== */
.sw-shell{position:fixed;right:0;top:50%;transform:translateY(-50%);z-index:300;display:flex;align-items:stretch}

.palette-panel{background:color-mix(in srgb,var(--bg) 92%,transparent);backdrop-filter:blur(22px);-webkit-backdrop-filter:blur(22px);border:1px solid var(--bd);border-right:none;border-radius:14px 0 0 14px;width:0;overflow:hidden;transition:width .45s cubic-bezier(.22,1,.36,1),background .75s,border-color .75s;display:flex;flex-direction:column;box-shadow:-4px 0 32px var(--sh)}
.palette-panel.open{width:222px}
.pp-inner{width:222px;padding:16px 16px 12px;flex:1;display:flex;flex-direction:column}
.pp-close-row{display:flex;justify-content:flex-end;margin-bottom:4px}
.pp-close-btn{background:none;border:none;cursor:pointer;color:var(--tx3);font-size:15px;line-height:1;padding:2px 5px;border-radius:4px;transition:color .2s,background .2s}
.pp-close-btn:hover{color:var(--ac);background:color-mix(in srgb,var(--ac) 10%,transparent)}
.pp-eyebrow{display:block;font-family:var(--fe);font-size:8px;letter-spacing:.28em;text-transform:uppercase;color:var(--tx3);margin-bottom:3px;transition:color .75s}
.pp-name{font-family:var(--fd);font-style:italic;font-size:13px;font-weight:var(--fwd);color:var(--ac);margin-bottom:10px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;transition:color .75s,font-family .1s}
.pp-row{display:flex;align-items:center;gap:8px;padding:4px 6px;border-radius:7px;cursor:pointer;transition:background .2s;margin-bottom:2px}
.pp-row:hover{background:color-mix(in srgb,var(--ac) 10%,transparent)}
.pp-swatch{width:17px;height:17px;border-radius:50%;flex-shrink:0;box-shadow:0 1px 4px var(--sh)}
.pp-label{display:block;font-size:9px;color:var(--tx3);line-height:1.2;transition:color .75s}
.pp-hex{display:block;font-family:'Josefin Sans',monospace;font-size:11px;font-weight:300;letter-spacing:.06em;color:var(--tx);transition:color .75s}
.pp-copy-ic{opacity:0;color:var(--tx3);transition:opacity .2s;flex-shrink:0}
.pp-row:hover .pp-copy-ic{opacity:1}
.pp-hint{margin-top:8px;padding-top:7px;border-top:1px solid var(--bd);font-size:8px;color:var(--tx3);letter-spacing:.06em;text-align:center;transition:color .75s,border-color .75s}

.sw-panel{background:color-mix(in srgb,var(--bg) 84%,transparent);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border:1px solid var(--bd);border-right:none;border-radius:14px 0 0 14px;padding:8px 0;display:flex;flex-direction:column;align-items:center;box-shadow:-2px 0 24px var(--sh);transition:background .75s,border-color .75s}
