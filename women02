let CC=1,CP=1,PPO=false;

function apply(c,p){
  CC=c;CP=p;
  document.body.setAttribute('data-cat',c);
  document.body.setAttribute('data-pat',p);
  document.querySelectorAll('.sw-btn').forEach(b=>b.classList.toggle('active',+b.dataset.c===c&&+b.dataset.p===p));
  const sw=T[c+'-'+p]?.sw||[];
  document.querySelectorAll('#sr1 .sw,#sr2 .sw').forEach((el,i)=>{if(sw[i])el.style.background=sw[i]});
  if(PPO)renderPP();
}

function renderPP(){
  const t=T[CC+'-'+CP];if(!t)return;
  document.getElementById('ppName').textContent=t.n;
  document.getElementById('ppRows').innerHTML=t.c.map(c=>`<div class="pp-row" onclick="copyH('${c.h}')"><div class="pp-swatch" style="background:${c.h}"></div><div style="flex:1;min-width:0"><span class="pp-label">${c.l}</span><span class="pp-hex">${c.h}</span></div><span class="pp-copy-ic"><svg width="11" height="11" viewBox="0 0 11 11" fill="none"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.1"/><path d="M7.5 3V2A1.5 1.5 0 006 .5H2A1.5 1.5 0 00.5 2v4A1.5 1.5 0 002 7.5H3" stroke="currentColor" stroke-width="1.1"/></svg></span></div>`).join('');
}

function togglePP(){PPO=!PPO;const p=document.getElementById('pp');if(PPO){renderPP();p.classList.add('open')}else p.classList.remove('open')}
function closePP(){PPO=false;document.getElementById('pp').classList.remove('open')}

function copyH(h){
  const show=()=>{const t=document.getElementById('toast');t.textContent=h+'  をコピーしました';t.classList.add('show');setTimeout(()=>t.classList.remove('show'),1900)};
  if(navigator.clipboard)navigator.clipboard.writeText(h).then(show).catch(()=>{fb(h);show()});else{fb(h);show()}
}
function fb(h){const t=document.createElement('textarea');t.value=h;document.body.appendChild(t);t.select();document.execCommand('copy');document.body.removeChild(t)}

document.querySelectorAll('.sw-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const c=+btn.dataset.c,p=+btn.dataset.p;
    if(c===CC&&p===CP)togglePP();else apply(c,p);
  });
});

apply(1,1);

window.addEventListener('scroll',()=>document.getElementById('nav').classList.toggle('scrolled',scrollY>50),{passive:true});

new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in')}),{threshold:.1,rootMargin:'0px 0px -30px 0px'}).observe.bind(null);
const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in')}),{threshold:.1,rootMargin:'0px 0px -30px 0px'});
document.querySelectorAll('.r').forEach(el=>io.observe(el));

function toggleFaq(el){const item=el.parentElement,was=item.classList.contains('open');document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));if(!was)item.classList.add('open')}
</script>
